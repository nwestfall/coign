{
  "name": "coign-sdk",
  "version": "0.1.0",
  "description": "Coign — a private, page-aware AI agent SDK that runs entirely in the browser.",
  "type": "module",
  "main": "dist/coign-sdk.cjs.js",
  "module": "dist/coign-sdk.es.js",
  "types": "dist/coign-sdk.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node scripts/generate-sri.js",
    "build:types": "tsc --emitDeclarationOnly",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.78",
    "minisearch": "^7.1.0"
  },
  "keywords": [
    "webllm",
    "ai",
    "chatbot",
    "client-side",
    "privacy",
    "sdk"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nathanwestfall/coign-sdk.git"
  }
}
